// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PREPARING
  PARTIALLY_READY
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REOPENED
}

enum SaleType {
  COUNTER
  TABLE
  OWN_DELIVERY
  THIRD_PARTY
}

enum UnitType {
  G
  ML
  UN
  KG
  L
}

enum DriverStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

enum VehicleType {
  Moto
  Carro
  Bicicleta
}

enum SessionStatus {
  available
  occupied
  billing
}

enum RejectionType {
  AUTO
  MANUAL
}

model User {
  id                 String     @id @default(uuid())
  name               String
  email              String     @unique
  password           String
  phone              String?
  recoveryCode       String?
  mustChangePassword Boolean    @default(true)
  active             Boolean    @default(true)
  permissions        String[]
  createdAt          DateTime   @default(now())
}

model Client {
  id            String       @id @default(uuid())
  name          String
  phone         String
  email         String?
  password      String?
  googleId      String?      @unique
  pin           String?
  recoveryCode  String?
  mustChangePassword Boolean    @default(false)
  document      String?
  cep           String?
  street        String?
  addressNumber String?
  neighborhood  String?
  city          String?
  state         String?
  complement    String?
  addresses     String[]
  totalOrders   Int          @default(0)
  lastOrderDate String?
  orders        Order[]
  receivables   Receivable[]
  notifications Notification[]
  avatarUrl     String?
}

model Waiter {
  id            String         @id @default(uuid())
  name          String
  phone         String
  email         String?        @unique
  active        Boolean        @default(true)
  orders        Order[]
  tableSessions TableSession[]
}

model Product {
  id         String       @id @default(uuid())
  name       String
  price      Float
  category   String
  stock      Int          @default(0)
  imageUrl   String
  active     Boolean      @default(true)
  ncm        String?
  cfop       String?
  cest       String?
  recipe     RecipeItem[]
  orderItems OrderItem[]
}

model InventoryItem {
  id        String              @id @default(uuid())
  name      String
  unit      UnitType
  quantity  Float
  minStock  Float
  cost      Float
  recipes   RecipeItem[]
  movements InventoryMovement[]
}

model InventoryMovement {
  id              String        @id @default(uuid())
  timestamp       DateTime      @default(now())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  type            String // INPUT, OUTPUT, ADJUSTMENT
  quantity        Float
  reason          String // e.g., "Sale", "Manual Adjustment", "Restock"
  orderId         String? // Link to order if applicable
}

model RecipeItem {
  id              String        @id @default(uuid())
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  quantity        Float
  wasteFactor     Float
}

model SupportMessage {
  id        String   @id @default(uuid())
  clientId  String?
  userName  String?
  message   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  isRead    Boolean  @default(false)
}

model Order {
  id                  String           @id @default(uuid())
  clientId            String
  client              Client           @relation(fields: [clientId], references: [id])
  clientName          String
  clientAddress       String?
  clientPhone         String?
  clientEmail         String?
  clientDocument      String?
  clientCep           String?
  clientStreet        String?
  clientNeighborhood  String?
  clientCity          String?
  clientState         String?
  clientComplement    String?
  items               OrderItem[]
  total               Float
  status              OrderStatus      @default(PENDING)
  type                SaleType
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @default(now()) @updatedAt
  paymentMethod       String?
  driverId            String?
  driver              DeliveryDriver?  @relation(fields: [driverId], references: [id])
  assignedAt          DateTime?
  deliveryFee         Float?
  tableNumber         Int?
  waiterId            String?
  waiter              Waiter?          @relation(fields: [waiterId], references: [id])
  isOriginDigitalMenu Boolean          @default(false)
  isOriginDeliveryApp Boolean          @default(false)
  rejections          OrderRejection[]
  messages            OrderMessage[]
  // Fiscal Fields
  nfeStatus           String? // PENDING, EMITTED, ERROR
  nfeNumber           String?
  nfeUrl              String?
  nfeError            String?
  splitAmount1        Float?
  appliedServiceFee   Float? // Optional Service Fee recorded at the time of order
  digitalPin          String? // Store PIN for session recovery on reopen
  digitalToken        String? // Store token for session recovery on reopen
  receivables         Receivable[]
  // Mercado Pago
  mpPreferenceId      String?
  mpPaymentId         String?
  paymentStatus       String?          @default("PENDING") // PENDING, APPROVED, REJECTED
  
  // Promotion Fields
  couponId            String?
  coupon              Coupon?          @relation(fields: [couponId], references: [id])
  discountValue       Float?           @default(0)
}

model Coupon {
  id              String      @id @default(uuid())
  code            String      @unique
  description     String?
  type            String      // FIXED, PERCENTAGE, FREE_SHIPPING
  value           Float?      @default(0)
  minOrderValue   Float?      @default(0)
  maxDiscount     Float?
  startDate       DateTime    @default(now())
  endDate         DateTime?
  usageLimit      Int?
  usedCount       Int         @default(0)
  active          Boolean     @default(true)
  createdAt       DateTime    @default(now())
  orders          Order[]
}

model Campaign {
  id              String      @id @default(uuid())
  title           String
  message         String
  type            String      // PUSH, IN_APP, BOTH
  segment         String?     // ALL, ACTIVE, INACTIVE, etc.
  scheduledAt     DateTime?
  sentAt          DateTime?
  status          String      @default("DRAFT") // DRAFT, SCHEDULED, SENT, CANCELLED
  createdAt       DateTime    @default(now())
}

model Notification {
  id              String      @id @default(uuid())
  clientId        String
  client          Client      @relation(fields: [clientId], references: [id])
  title           String
  message         String
  isRead          Boolean     @default(false)
  link            String?     // Optional link to open (e.g., product page or coupon)
  createdAt       DateTime    @default(now())
}

model Receivable {
// ... existing Receivable model ...

  id            String    @id @default(uuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id])
  orderId       String
  order         Order     @relation(fields: [orderId], references: [id])
  amount        Float
  dueDate       DateTime
  paymentMethod String? // Method used when the receivables are finally PAID
  status        String    @default("PENDING") // PENDING, PAID
  observations  String?
  createdAt     DateTime  @default(now())
  paidAt        DateTime?
}

model OrderItem {
  id             String        @id @default(uuid())
  orderId        String?
  order          Order?        @relation(fields: [orderId], references: [id])
  tableSessionId Int?
  tableSession   TableSession? @relation(fields: [tableSessionId], references: [tableNumber])
  productId      String
  product        Product       @relation(fields: [productId], references: [id])
  quantity       Int
  price          Float
  isReady        Boolean       @default(false)
  readyAt        DateTime?
  observations   String?
}

model TableSession {
  tableNumber         Int           @id
  status              SessionStatus @default(available)
  items               OrderItem[]
  clientName          String?
  clientPhone         String?
  clientEmail         String?
  clientDocument      String?
  clientId            String?
  waiterId            String?
  waiter              Waiter?       @relation(fields: [waiterId], references: [id])
  startTime           DateTime      @default(now())
  clientAddress       String?
  clientCep           String?
  clientComplement    String?
  hasPendingDigital   Boolean       @default(false)
  pendingReviewItems  String? // To store stringified array of requested digital items before approval
  isOriginDigitalMenu Boolean       @default(false)
  pin                 String?
  sessionToken        String?
}

model DeliveryDriver {
  id           String           @id @default(uuid())
  name         String
  phone        String
  email        String?
  address      String?
  vehiclePlate String
  vehicleModel String
  vehicleBrand String
  vehicleType  VehicleType
  status       DriverStatus     @default(AVAILABLE)
  active       Boolean          @default(true)
  orders       Order[]
  rejections   OrderRejection[]
}

model AuditLog {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  userId    String
  userName  String
  action    String
  details   String
}

model BusinessSettings {
  key                  String  @id
  name                 String
  cnpj                 String
  address              String
  phone                String
  deliveryFee          String
  tableCount           Int
  restaurantLat        Float?
  restaurantLng        Float?
  geofenceRadius       Int     @default(30)
  isManuallyClosed     Boolean @default(false)
  operatingHours       String  @default("[]")
  orderTimeoutMinutes  Int     @default(5)
  maxChange            Float   @default(191)
  serviceFeeStatus     Boolean @default(true)
  serviceFeePercentage Float   @default(10)
  // NFC-e Fields
  ie                   String?
  cscId                String?
  cscToken             String?
  isNfeProduction      Boolean @default(false)
  enableNfcEmission    Boolean @default(false)
  waiterPrivacyEnabled Boolean @default(false)
  waiterPrivacyTimer   Int     @default(60)

  enableDeliveryApp    Boolean @default(true)
  enableDigitalMenu    Boolean @default(true)
  enableWaiterApp      Boolean @default(true)
  enableDriverApp      Boolean @default(true)
  autoCloseTime        String  @default("00:00")
  waiterLockEnabled    Boolean @default(true)
  qrCodeBaseUrl        String?
  facebook             String?
  instagram            String?
  website              String?
  campaignLogoUrl      String?
  appBannerUrl         String?
}

model ChatMessage {
  id           String   @id @default(uuid())
  content      String
  timestamp    DateTime @default(now())
  driverId     String
  isFromDriver Boolean
  senderName   String
}

model OrderRejection {
  id        String         @id @default(uuid())
  timestamp DateTime       @default(now())
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id])
  driverId  String
  driver    DeliveryDriver @relation(fields: [driverId], references: [id])
  type      RejectionType
  reason    String?
}

model CashSession {
  id             String    @id @default(uuid())
  openedAt       DateTime  @default(now())
  openedBy       String
  openedByName   String
  initialBalance Float
  closedAt       DateTime?
  closedBy       String?
  closedByName   String?
  status         String    @default("OPEN")

  reportedCash   Float?
  reportedPix    Float?
  reportedCredit Float?
  reportedDebit  Float?
  reportedOthers Float?
  reportedFiado  Float?

  systemCash   Float?
  systemPix    Float?
  systemCredit Float?
  systemDebit  Float?
  systemOthers Float?
  systemFiado  Float?

  totalSales   Float?
  orphanSales  Float?
  difference   Float?
  observations String?
}

model Feedback {
  id          String   @id @default(uuid())
  name        String?
  message     String
  tableNumber Int
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model OrderMessage {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  sender    String   // 'STORE' | 'CLIENT'
  text      String
  createdAt DateTime @default(now())
}
